# ============================================================
# AI Fitness Coach v1 — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values

# --- Application ---
APP_NAME=AI Fitness Coach
APP_ENV=development          # development | production
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key  # REQUIRED for production — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"

# --- CORS ---
# Comma-separated origins. Use "*" for dev, specific domains for production.
# Example: CORS_ORIGINS=https://coach.example.com,https://app.example.com
CORS_ORIGINS=*

# --- Database ---
# SQLite (default for development):
# DATABASE_URL=sqlite+aiosqlite:///./data/coach.db
# PostgreSQL (recommended for production):
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/fitness_coach

# --- wger (Workout Provider) ---
WGER_BASE_URL=http://localhost:8001/api/v2
WGER_API_TOKEN=your-wger-api-token

# --- Tandoor Recipes (Recipe Provider) ---
TANDOOR_BASE_URL=http://localhost:8002/api
TANDOOR_API_TOKEN=your-tandoor-api-token

# --- LLM Provider ---
# Options: ollama, openai, anthropic
LLM_PROVIDER=ollama
LLM_MODEL=llama3
LLM_BASE_URL=http://localhost:11434
# Only needed for cloud providers:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- wger Docker Config ---
WGER_DJANGO_SECRET_KEY=wger-secret-key-change-me
WGER_DB_PASSWORD=wger-db-password

# --- Tandoor Docker Config ---
TANDOOR_SECRET_KEY=tandoor-secret-key-change-me
TANDOOR_DB_PASSWORD=tandoor-db-password
TANDOOR_PORT=8002
